# HT-Sense firmware configuration
# Copy to .env and set real values before deploying.

# Data mode: NC | LS | SS | RT | LSRT | SSRT
DATA_MODE=NC

# Connectivity
WIFI_SSID=YOUR_WIFI_SSID
WIFI_PASSWORD=YOUR_WIFI_PASSWORD

# MQTT (used by RT/LSRT/SSRT modes)
MQTT_BROKER=192.168.1.100
MQTT_TOPIC=ht-sense/data

# HTTP sync (used by SS/SSRT modes)
SYNC_URL=https://example.com/api/upload
SYNC_TOKEN=YOUR_SYNC_TOKEN

# Optional features
ENABLE_NTP=false
NTP_SERVER=pool.ntp.org
USE_SECURE_STORAGE=false
ENABLE_OTA=false
OTA_URL=https://example.com/firmware.bin
